# ============================================
# 金鹰工单KPI管理系统 - 环境配置模板
# ============================================
# 首次部署说明：
# 1. 复制此文件为 .env （或首次启动会自动创建）
# 2. 填写下面的配置项
# 3. 首次启动 DEV_MODE=1，可用任意工号登录为管理员
# 4. 登录后导入人力清单 → 设置 DEV_MODE=0 进入生产模式

# --- 服务器 ---
SERVER_HOST=127.0.0.1
SERVER_PORT=8765
# 开发模式：1=允许空库登录(首次部署用)，0=生产模式(必须有人力数据)
DEV_MODE=1

# --- JWT认证 ---
JWT_SECRET=YOUR_JWT_SECRET_HERE-change-me

# --- AI对话（可在系统配置页前端修改） ---
AI_API_KEY=
AI_MODEL=qwen/qwen3.5-122b-a10b
AI_INVOKE_URL=https://integrate.api.nvidia.com/v1/chat/completions
AI_MAX_TOKENS=16384
AI_TEMPERATURE=0.60

# --- BI爬虫 ---
SCRAPER_ACCOUNT=
SCRAPER_PASSWORD=

# --- WY筹建专项 ---
WY_BASE_URL=http://58.213.109.123:8181
WY_TOKEN=
WY_USERNAME=
WY_PASSWORD=

# --- IPMS设备管理 ---
IPMS_USERNAME=
IPMS_PASSWORD=

# --- Gitee版本更新 ---
GITEE_TOKEN=
